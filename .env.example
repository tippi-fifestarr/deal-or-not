# ═══════════════════════════════════════════════════════════════
# Deal or NOT! — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.

# ── Deployer / Host Wallet ──
# Private key for deploying contracts and hosting games
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# ── Claude Player 3 (Burner Wallet) ──
# Used by the CLI scripts in scripts/ to enter the lottery as a 3rd player.
# This is a BURNER wallet — only send small amounts of testnet ETH.
#
# Burner address: 0xC96Bcb1EACE35d09189a6e52758255b8951a7587
CLAUDE_PRIVATE_KEY=0x7bccdcecede835466aafe20ea5aa11bad825c5bea940473e4f865b8013fc2340

# ── RPC ──
RPC_URL=https://sepolia.base.org

# ── Frontend (packages/nextjs/.env.local) ──
# NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_key
# NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wc_project_id

# ── Chainlink (for Schrödinger's Case / CashCase.sol) ──
# CHAINLINK_VRF_SUBSCRIPTION_ID=
# CHAINLINK_VRF_KEY_HASH=
