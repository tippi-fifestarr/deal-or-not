# CRE Secrets Configuration
# Copy this file to secrets.yaml and fill in your actual values
# NEVER commit secrets.yaml to git

# Deployer private key for signing CRE reports
PRIVATE_KEY: "0x..."

# Base Sepolia RPC URL (for reading contract state)
RPC_URL: "https://sepolia.base.org"

# Optional: Monitoring and alerting
PAGERDUTY_KEY: ""
SLACK_WEBHOOK: ""

# Optional: Rate limiting and security
API_KEY: ""
AUTH_TOKEN: ""
