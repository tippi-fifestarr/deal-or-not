# Deal or NOT — Convergence
# Base Sepolia Testnet
#
# Quick start for judges:
#   1. cp .env.example .env
#   2. Replace the private key below with your burner wallet's key
#   3. Get Base Sepolia ETH from https://faucet.base.org
#   4. Run: bash scripts/play-game.sh create
#
# Or use our pre-funded burner wallets (testnet only, don't store real funds):

# ── Wallets (burner testnet only!) ──
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
DEPLOYER_ADDRESS=0x_YOUR_ADDRESS_HERE

# Optional second wallet for testing player vs host separation:
# PLAYER_PRIVATE_KEY=0x_PLAYER_KEY_HERE
# PLAYER_ADDRESS=0x_PLAYER_ADDRESS_HERE

# ── Network ──
# Default public RPC works fine. Alchemy is faster:
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Chainlink Contracts (Base Sepolia — no changes needed) ──
ETH_USD_PRICE_FEED=0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1
VRF_COORDINATOR=0x5C210eF41CD1a72de73bF76eC39637bB0d3d7BEE
VRF_KEY_HASH=0x9e1344a1247c8a1785d0a4681a27152bffdb43666ae5bf7d14d24a5efd44bf71
